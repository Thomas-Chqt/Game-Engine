inputs:
  - name: player_jump
    input:
      type: Action
      mapper:
        type: KeyboardButton
        data:
          button: space
  - name: player_move
    input:
      type: Range2D
      mapper:
        type: KeyboardButton
        data:
          xPos: d
          xNeg: a
          xScale: 1
          yPos: w
          yNeg: s
          yScale: 1
          triggerValue: 0.5
  - name: player_rotate
    input:
      type: Range2D
      mapper:
        type: KeyboardButton
        data:
          xPos: up
          xNeg: down
          xScale: 1
          yPos: left
          yNeg: right
          yScale: 1
          triggerValue: 0.5
